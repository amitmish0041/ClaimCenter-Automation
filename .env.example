# ── Environment selector ─────────────────────────────────────────────────────
# CC_ENV=onprem    → Donegal on-premise (ExtJS, ClaimCenter.do)
# CC_ENV=cloud     → Guidewire Cloud (React/Jutro)
CC_ENV=onprem

# ── URLs ─────────────────────────────────────────────────────────────────────
CC_BASE_URL_ONPREM=http://test-claimcenter.donegalgroup.com/cc/ClaimCenter.do
CC_BASE_URL_CLOUD=https://donegal-cc.guidewire.net/cc/

# Set whichever env you are running:
CC_BASE_URL=http://test-claimcenter.donegalgroup.com/cc/ClaimCenter.do

# ── Credentials ───────────────────────────────────────────────────────────────
CC_USER=your_username
CC_PASS=your_password

# ── Policy numbers (same across both envs if policies are synced) ─────────────
POLICY_PA_AUTO=XXXX-000001
POLICY_MI_AUTO=XXXX-000002
POLICY_HO_PA=XXXX-000003
POLICY_HO_VA=XXXX-000004
POLICY_WC_PA=XXXX-000005
POLICY_WC_MI=XXXX-000006
POLICY_BOP_PA=XXXX-000007
POLICY_BOP_DE=XXXX-000008
POLICY_CP_PA=XXXX-000009
POLICY_CP_MI=XXXX-000010
POLICY_CAU_PA=XXXX-000011
